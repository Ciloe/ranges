{
    "name": "ciloe/ranges",
    "description": "A ranges representation library for PHP",
    "type": "library",
    "require": {
        "php": "8.*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
    "license": "AGPL-3.0-or-later",
    "autoload": {
        "psr-4": {
            "Ciloe\\Ranges\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Ciloe\\Ranges\\": "tests/"
        }
    },
    "config": {
        "bin-dir": "bin",
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true
    },
    "authors": [
        {
            "name": "Jimmy E",
            "email": "Ciloe@users.noreply.github.com"
        }
    ],
    "minimum-stability": "stable"
}
