{
    "name": "ciloe/ranges",
    "description": "A ranges representation library for PHP",
    "type": "library",
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "phpstan/phpstan": "^1.10",
        "phpunit/phpunit": "^11.5",
        "squizlabs/php_codesniffer": "^3.7",
        "symplify/easy-coding-standard": "^12.0"
    },
    "license": "GPL-3.0-or-later",
    "autoload": {
        "psr-4": {
            "Ciloe\\Ranges\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Ciloe\\Ranges\\": "tests/"
        }
    },
    "config": {
        "bin-dir": "bin",
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true
    },
    "authors": [
        {
            "name": "Jimmy E",
            "email": "Ciloe@users.noreply.github.com"
        }
    ],
    "minimum-stability": "stable",
    "scripts": {
        "validate": "composer validate --strict",
        "phpstan": "./bin/phpstan analyse --no-progress",
        "phpcs": "./bin/phpcs",
        "ecs": "./bin/ecs check",
        "ecs-fix": "./bin/ecs check --fix",
        "phpunit": "./bin/phpunit tests",
        "ci": [
            "@validate",
            "@phpstan",
            "@phpcs",
            "@ecs",
            "@phpunit"
        ]
    }
}
